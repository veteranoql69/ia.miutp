# miUTP - VARIABLES DE ENTORNO DE EJEMPLO (SIN SECRETOS)
# Copia este archivo como .env y edita los valores.

# 1. CONFIGURACIÓN DE NEXT.JS
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 2. INSTANCIA DE SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.cl
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 3. BASE DE DATOS DIRECTA
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# 4. MONITOREO DE IA - LANGFUSE
NEXT_PUBLIC_LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://your-langfuse-host.cl

# 5. GOOGLE GEN AI / GEMINI API
GEMINI_API_KEY=your-gemini-api-key-here

# 6. INSTANCIA DE STIRLING-PDF
STIRLING_PDF_API_URL=https://your-stirling-pdf-url.cl
STIRLING_PDF_API_KEY=your-stirling-pdf-key-here

# 7. CONFIGURACIÓN GENERAL
MAX_UPLOAD_SIZE_MB=50
